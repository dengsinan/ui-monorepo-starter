{
  "name": "@dengsinan/ui",
  "version": "1.0.1",
  "description": "React 19 + Ant Design UI components package.",
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.less"
  ],
  "publishConfig": {
    "access": "public"
  },
  "source": "./src/index.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.node.json",
    "clean": "node --eval \"const fs = require('node:fs'); fs.rmSync('dist', { recursive: true, force: true });\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "react",
    "antd",
    "ui",
    "components"
  ],
  "author": "dengsinan",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dengsinan/ui-monorepo-starter.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/dengsinan/ui-monorepo-starter#readme",
  "bugs": {
    "url": "https://github.com/dengsinan/ui-monorepo-starter/issues"
  },
  "packageManager": "pnpm@10.13.1",
  "peerDependencies": {
    "@ant-design/cssinjs": "^2.0.0",
    "antd": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@ant-design/cssinjs": "^2.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "less": "^4.6.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lodash-es": "^4.17.21"
  }
}
